{
  "schema_version": 1,
  "name": "claude",
  "description": "Claude Code plugin and matching nono profile. Provides sandbox-aware diagnostics on permission failures and ships the claude-code profile via the registry.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.42.0",
  "artifacts": [
    {
      "type": "profile",
      "path": "policy.json",
      "install_as": "claude-code"
    },
    {
      "type": "plugin",
      "path": ".claude-plugin/plugin.json",
      "install_dir": "~/.claude/plugins/nono/.claude-plugin"
    },
    {
      "type": "plugin",
      "path": "hooks/hooks.json",
      "install_dir": "~/.claude/plugins/nono/hooks"
    },
    {
      "type": "plugin",
      "path": "bin/nono-hook.sh",
      "install_dir": "~/.claude/plugins/nono/bin"
    },
    {
      "type": "plugin",
      "path": "bin/nono-hook-bash.sh",
      "install_dir": "~/.claude/plugins/nono/bin"
    },
    {
      "type": "plugin",
      "path": "skills/nono-sandbox/SKILL.md",
      "install_dir": "~/.claude/plugins/nono/skills/nono-sandbox"
    }
  ]
}
